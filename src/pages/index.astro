---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getBlogPosts } from "../lib/blog";
import BlogPostCard from "../components/BlogPostCard.astro";

const allPosts = await getBlogPosts();
const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="terenced">
  <section class="py-12">
    <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight">
      <span>I&apos;m Terry,</span>
    </h1>
    <p class="pt-2 text-2xl font-semibold">
      a full-stack 🥞 developer from Canada 🇨🇦
    </p>
    <p class="mt-4 text-lg text-base-content/60 leading-relaxed max-w-lg">
      Welcome to my corner of the internet. I (very rarely) write about things I
      find interesting.
    </p>
  </section>

  {
    recentPosts.length > 0 && (
      <section class="pt-4">
        <h2 class="text-sm font-mono tracking-widest uppercase text-base-content/40 mb-2">
          Recent Posts
        </h2>
        <div>
          {recentPosts.map((post) => (
            <BlogPostCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              id={post.id}
              tags={post.data.tags}
            />
          ))}
        </div>
        <a
          href="/blog"
          class="inline-block mt-6 text-sm text-primary hover:underline"
        >
          View all posts &rarr;
        </a>
      </section>
    )
  }
</BaseLayout>
