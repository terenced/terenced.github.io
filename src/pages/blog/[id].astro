---
import { render } from 'astro:content';
import { getBlogPosts } from '../../lib/blog';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} | terenced`} description={post.data.description}>
  <article class="py-12">
    <header class="mb-10">
      <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight">
        {post.data.title}
      </h1>
      <time
        class="block mt-3 text-sm text-base-content/40 font-mono"
        datetime={post.data.pubDate.toISOString()}
      >
        {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-2">
          {post.data.tags.map((tag: string) => (
            <span class="text-xs text-base-content/40 font-mono">#{tag}</span>
          ))}
        </div>
      )}
    </header>
    <hr class="border-base-content/10 mb-10" />
    <div class="prose prose-lg max-w-none">
      <Content />
    </div>
  </article>
  <a href="/blog" class="inline-block mt-4 mb-12 text-sm text-primary hover:underline">
    &larr; Back to all posts
  </a>
</BaseLayout>
