---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  id: string;
  tags?: string[];
}
const { title, description, pubDate, id, tags } = Astro.props;
---

<a
  href={`/blog/${id}`}
  class="group block py-6 border-b border-base-content/10 last:border-b-0 transition-colors"
>
  <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
    <h2 class="text-lg font-medium group-hover:text-primary transition-colors">
      {title}
    </h2>
    <time
      class="text-sm text-base-content/40 shrink-0 font-mono"
      datetime={pubDate.toISOString()}
    >
      {pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
    </time>
  </div>
  <p class="mt-2 text-base-content/60 text-sm leading-relaxed">{description}</p>
  {tags && tags.length > 0 && (
    <div class="mt-2 flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="text-xs text-base-content/40 font-mono">#{tag}</span>
      ))}
    </div>
  )}
</a>
